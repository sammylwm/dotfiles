binds {
    //#"Launch & IPC"

    // apps
    Mod+Return hotkey-overlay-title="Open terminal (foot)" { spawn "foot"; }
    Mod+B hotkey-overlay-title="Open Firefox browser" { spawn "firefox"; }
    Super+Alt+L hotkey-overlay-title="Lock screen (swaylock)" { spawn "swaylock"; }

    // QuickShell IPC
    Mod+R hotkey-overlay-title="Toggle launcher (qs ipc)" { spawn-sh "qs ipc call launcher toggle"; }
    Mod+I hotkey-overlay-title="Toggle settings panel (qs ipc)" { spawn-sh "qs ipc call settings toggle"; }
    Mod+O hotkey-overlay-title="Toggle wallpaper panel (qs ipc)" { spawn-sh "qs ipc call wallpaper toggle"; }
    Mod+Slash hotkey-overlay-title="Open keybind cheat sheet panel" { spawn "qs" "ipc" "call" "plugin" "togglePanel" "keybind-cheatsheet"; }

    // accessibility
    Super+Alt+S allow-when-locked=true hotkey-overlay-title="Toggle Orca screen reader" { spawn-sh "pkill orca || exec orca"; }


    //#"Media"

    // volume
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title="Volume up" { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title="Volume down" { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute allow-when-locked=true hotkey-overlay-title="Toggle mute audio" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute allow-when-locked=true hotkey-overlay-title="Toggle mute microphone" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    
    // media control
    KP_Add allow-when-locked=true hotkey-overlay-title="Play / pause media" { spawn-sh "playerctl play-pause"; }
    KP_Subtract allow-when-locked=true hotkey-overlay-title="Previous track" { spawn-sh "playerctl previous"; }
    KP_Multiply allow-when-locked=true hotkey-overlay-title="Next track" { spawn-sh "playerctl next"; }


    //#"Brightness"

    XF86MonBrightnessUp allow-when-locked=true hotkey-overlay-title="Increase brightness" { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title="Decrease brightness" { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }


    //#"Window management"

    Mod+Q repeat=false hotkey-overlay-title="Close window" { close-window; }

    Mod+F hotkey-overlay-title="Maximize column" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Fullscreen window" { fullscreen-window; }

    Mod+V hotkey-overlay-title="Toggle floating window" { toggle-window-floating; }
    Mod+Shift+V hotkey-overlay-title="Switch between floating and tiling" { switch-focus-between-floating-and-tiling; }

    Mod+W hotkey-overlay-title="Toggle tabbed layout" { toggle-column-tabbed-display; }

    Mod+D hotkey-overlay-title="Switch preset column width" { switch-preset-column-width; }

    Mod+Shift+R hotkey-overlay-title="Switch preset window height" { switch-preset-window-height; }
    Mod+Ctrl+R hotkey-overlay-title="Reset window height" { reset-window-height; }

    Mod+Ctrl+F hotkey-overlay-title="Expand column to full width" { expand-column-to-available-width; }

    Mod+C hotkey-overlay-title="Center column" { center-column; }
    Mod+Ctrl+C hotkey-overlay-title="Center visible columns" { center-visible-columns; }

    Mod+Minus hotkey-overlay-title="Decrease column width" { set-column-width "-10%"; }
    Mod+Equal hotkey-overlay-title="Increase column width" { set-column-width "+10%"; }

    Mod+Shift+Minus hotkey-overlay-title="Decrease window height" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Increase window height" { set-window-height "+10%"; }


    //#"Navigation focus"

    // columns/windows
    Mod+Left hotkey-overlay-title="Focus column left" { focus-column-left; }
    Mod+Right hotkey-overlay-title="Focus column right" { focus-column-right; }
    Mod+H hotkey-overlay-title="Focus column left (vim)" { focus-column-left; }
    Mod+L hotkey-overlay-title="Focus column right (vim)" { focus-column-right; }

    Mod+Down hotkey-overlay-title="Focus window down" { focus-window-down; }
    Mod+Up hotkey-overlay-title="Focus window up" { focus-window-up; }
    Mod+J hotkey-overlay-title="Focus window down (vim)" { focus-window-down; }
    Mod+K hotkey-overlay-title="Focus window up (vim)" { focus-window-up; }


    //#"Navigation move"

    Mod+Ctrl+Left hotkey-overlay-title="Move column left" { move-column-left; }
    Mod+Ctrl+Right hotkey-overlay-title="Move column right" { move-column-right; }
    Mod+Ctrl+H hotkey-overlay-title="Move column left (vim)" { move-column-left; }
    Mod+Ctrl+L hotkey-overlay-title="Move column right (vim)" { move-column-right; }

    Mod+Ctrl+Down hotkey-overlay-title="Move window down" { move-window-down; }
    Mod+Ctrl+Up hotkey-overlay-title="Move window up" { move-window-up; }
    Mod+Ctrl+J hotkey-overlay-title="Move window down (vim)" { move-window-down; }
    Mod+Ctrl+K hotkey-overlay-title="Move window up (vim)" { move-window-up; }


    //#"Workspaces"

    Mod+Page_Down hotkey-overlay-title="Focus workspace down" { focus-workspace-down; }
    Mod+Page_Up hotkey-overlay-title="Focus workspace up" { focus-workspace-up; }
    Mod+U hotkey-overlay-title="Focus workspace down (vim)" { focus-workspace-down; }

    Mod+Ctrl+Page_Down hotkey-overlay-title="Move column to workspace down" { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up hotkey-overlay-title="Move column to workspace up" { move-column-to-workspace-up; }
    Mod+Ctrl+U hotkey-overlay-title="Move column to workspace down (vim)" { move-column-to-workspace-down; }
    Mod+Ctrl+I hotkey-overlay-title="Move column to workspace up (vim)" { move-column-to-workspace-up; }

    Mod+Shift+Page_Down hotkey-overlay-title="Move workspace down" { move-workspace-down; }
    Mod+Shift+Page_Up hotkey-overlay-title="Move workspace up" { move-workspace-up; }
    Mod+Shift+U hotkey-overlay-title="Move workspace down (vim)" { move-workspace-down; }
    Mod+Shift+I hotkey-overlay-title="Move workspace up (vim)" { move-workspace-up; }

    Mod+1 { focus-workspace 1; } 
    Mod+2 { focus-workspace 2; } 
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; } 
    Mod+5 { focus-workspace 5; } 
    Mod+6 { focus-workspace 6; } 
    Mod+7 { focus-workspace 7; } 
    Mod+8 { focus-workspace 8; } 
    Mod+9 { focus-workspace 9; } 
    Mod+Shift+1 { move-column-to-workspace 1; } 
    Mod+Shift+2 { move-column-to-workspace 2; } 
    Mod+Shift+3 { move-column-to-workspace 3; } 
    Mod+Shift+4 { move-column-to-workspace 4; } 
    Mod+Shift+5 { move-column-to-workspace 5; } 
    Mod+Shift+6 { move-column-to-workspace 6; } 
    Mod+Shift+7 { move-column-to-workspace 7; } 
    Mod+Shift+8 { move-column-to-workspace 8; } 
    Mod+Shift+9 { move-column-to-workspace 9; }


    //#"Scroll bindings"

    Mod+WheelScrollDown cooldown-ms=150 hotkey-overlay-title="Scroll workspace down" { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 hotkey-overlay-title="Scroll workspace up" { focus-workspace-up; }

    Mod+Ctrl+WheelScrollDown cooldown-ms=150 hotkey-overlay-title="Move column to workspace down (scroll)" { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp cooldown-ms=150 hotkey-overlay-title="Move column to workspace up (scroll)" { move-column-to-workspace-up; }

    Mod+WheelScrollRight hotkey-overlay-title="Focus column right (scroll)" { focus-column-right; }
    Mod+WheelScrollLeft hotkey-overlay-title="Focus column left (scroll)" { focus-column-left; }

    Mod+Ctrl+WheelScrollRight hotkey-overlay-title="Move column right (scroll)" { move-column-right; }
    Mod+Ctrl+WheelScrollLeft hotkey-overlay-title="Move column left (scroll)" { move-column-left; }

    Mod+Shift+WheelScrollDown hotkey-overlay-title="Focus column right (shift scroll)" { focus-column-right; }
    Mod+Shift+WheelScrollUp hotkey-overlay-title="Focus column left (shift scroll)" { focus-column-left; }

    Mod+Ctrl+Shift+WheelScrollDown hotkey-overlay-title="Move column right (shift scroll)" { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp hotkey-overlay-title="Move column left (shift scroll)" { move-column-left; }


    //#"Advanced window actions"

    Mod+BracketLeft hotkey-overlay-title="Consume or expel window left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Consume or expel window right" { consume-or-expel-window-right; }

    Mod+Comma hotkey-overlay-title="Consume window into column" { consume-window-into-column; }
    Mod+Period hotkey-overlay-title="Expel window from column" { expel-window-from-column; }

    Mod+Home hotkey-overlay-title="Focus first column" { focus-column-first; }
    Mod+End hotkey-overlay-title="Focus last column" { focus-column-last; }

    Mod+Ctrl+Home hotkey-overlay-title="Move column to first" { move-column-to-first; }
    Mod+Ctrl+End hotkey-overlay-title="Move column to last" { move-column-to-last; }


    //#"Screenshots"

    Print hotkey-overlay-title="Screenshot region" { screenshot; }
    Ctrl+Print hotkey-overlay-title="Screenshot screen" { screenshot-screen; }
    Alt+Print hotkey-overlay-title="Screenshot window" { screenshot-window; }
    Mod+Shift+T hotkey-overlay-title="Text scan" { spawn-sh "quickshell -c QuickSnip -n";}
}